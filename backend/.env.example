# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (nunca exposta no frontend)

# ── Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── E-mail (SMTP) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=senha_app_google

# ── Evolution API (WhatsApp) ──────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_INSTANCE=infrareport

# ── App ───────────────────────────────────────
APP_SECRET=troque_por_string_aleatoria_forte
STORAGE_PATH=./storage          # pasta local para salvar .docx gerados

# ── Google OAuth (Gmail integration) ──────────
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# URI deve estar cadastrada no Google Cloud Console → Credentials → OAuth 2.0
GOOGLE_REDIRECT_URI=https://seudominio.com/configuracoes?gmail_callback=1
